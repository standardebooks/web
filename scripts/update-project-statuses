#!/usr/bin/php
<?
require_once(__DIR__ . '/../lib/Core.php');

use Safe\DateTimeImmutable;
use function Safe\file_get_contents;
use function Safe\get_cfg_var;
use function Safe\getopt;
use function Safe\preg_match;
use function Safe\preg_match_all;
use function Safe\set_time_limit;
use function Safe\sleep;

function Usage(): void{
	Cli::PrintHelp(
		usage: '[command]update-project-statuses[/]',
		description: 'Update all active ebook projects with any recent activity, and change the status appropriately.',
	);
}

$restIndex = 0;
$options = getopt('h', ['help'], $restIndex);
$restIndex ??= $argc;

if(isset($options['h']) || isset($options['help'])){
	Usage();
}

$parameters = array_slice($argv, $restIndex);

if(sizeof($parameters) != 0){
	Usage();
}

set_time_limit(0);

/**
 * First, check for updated discussion in Google Groups. We can't poll Google Groups discussion pages because 1) they're div soup and it's hard to parse the correct last post date, and 2) Google often blocks our IP for doing automated requests.
 * Instead, we have a special email address subscribed to the S.E. Google Groups mailing list. It receives all email from the group. Then, we use IMAP to poll that email address daily for unread group messages. We extract the originating message ID from the email headers, and use that to find the project and update its timestamp.
 * We can't use Zoho webhooks because 1) webhooks don't include email headers, which we need for this, and 2) IMAP is more portable to a different email provider in the future.
 * We track *all* message IDs across the entire discussion, because sometimes the root message ID gets lost in the chain. Therefore if any message ID in a given email has been previously recorded, we assume it's part of the chain for this `Project`.
 */

/** @var string $username */
$username = get_cfg_var('se.secrets.zoho.mail.projects_username');
/** @var string $password */
$password = get_cfg_var('se.secrets.zoho.mail.projects_password');

/** @var array<int, Safe\DateTimeImmutable> $updatedProjectIds */
$updatedProjectIds = [];

/** @var array<int, object{'Timestamp': \Safe\DateTimeImmutable, 'MessageIds': array<string>}> $emailMessageIds An array containing objects, each of which represents one email, its timestamp, and all the related message IDs in its headers. */
$emailMessageIds = [];

try{
	$mailbox = new PhpImap\Mailbox('{imappro.zoho.com:993/imap/ssl}INBOX', $username, $password);
	// Expunge deleted mails upon mailbox close.
	$mailbox->setConnectionArgs(CL_EXPUNGE);

	// See <https://php.net/manual/en/function.imap-search.php>.
	$emailIds = $mailbox->searchMailbox('ALL');

	foreach($emailIds as $emailId){
		$email = $mailbox->getMail($emailId);

		if(
			preg_match('/\bstandardebooks@googlegroups\.com\b/iu', $email->toString ?? '')
			&&
			$email->messageId !== null
		){
			// Extract all message IDs present in various headers we're interested in.
			$headerString = trim($email->messageId . ' ' . ($email->headers->references ?? '') . ' ' . ($email->headers->in_reply_to ?? ''));
			preg_match_all('/<([^<>\s@]+?@[^<>\s@]+?)>/iu', $headerString, $matches);
			$messageIds = array_values(array_unique($matches[1]));

			if(sizeof($messageIds) > 0){
				// Get the timestamp of this email.
				$timestamp = NOW;
				if($email->date !== null){
					try{
						$timestamp = new DateTimeImmutable($email->date);
					}
					catch(\Throwable){
						// Pass.
					}
				}

				$object = new stdClass();
				$object->Timestamp = $timestamp;
				$object->MessageIds = $messageIds;
				$emailMessageIds[] = $object;
			}
		}

		$mailbox->markMailAsRead($emailId);
		$mailbox->moveMail($emailId, 'Trash');
	}
}
catch(\Exception $ex){
	$log = new Log();
	$log->Write('Failed connecting to IMAP account: ' . $ex->getMessage());
}

/**
 * Iterate over all `Project`s that are in progress or stalled and get their latest GitHub commit.
 *
 * If the last activity was more than 30 days old, mark the `Project` as stalled and send a reminder email.
 *
 * 60 days after the reminder email, the `Project` is marked as abandoned if there has not been any activity since.
 *
 * If a `Project` stalls and is re-activated, the process will repeat except no further reminder emails will be sent.
 */

/** @var array<Project> $projects */
$projects = Project::GetAllByStatuses([Enums\ProjectStatusType::InProgress, Enums\ProjectStatusType::AwaitingReview, Enums\ProjectStatusType::Reviewed, Enums\ProjectStatusType::Stalled]);

// Randomly sort `Project`s, in case we got rate limited in an earlier invocation, so we have a better chance of updating a different project this time.
shuffle($projects);

$apiKey = trim(file_get_contents('/standardebooks.org/config/secrets/se-vcs-bot@api.github.com'));
$oldestStalledTimestamp = new DateTimeImmutable('60 days ago');
$oldestAbandonedTimestamp = new DateTimeImmutable('60 days ago');
$continueFetchingLastCommitTimestamp = true;

foreach($projects as $project){
	/** @var array<int, string> $projectDiscussionMessageIds */
	$projectDiscussionMessageIds = [];

	foreach($emailMessageIds as $key => $emailMessage){
		if(
			$project->HasAnyMessage($emailMessage->MessageIds)
		){
			$projectDiscussionMessageIds = array_merge($projectDiscussionMessageIds, $emailMessage->MessageIds);

			if($project->LastDiscussionTimestamp < $emailMessage->Timestamp){
				$project->LastDiscussionTimestamp = $emailMessage->Timestamp;
			}

			// We matched this email to a `Project`, remove it from future checks.
			unset($emailMessageIds[$key]);
		}
	}

	$projectDiscussionMessageIds = array_values(array_unique($projectDiscussionMessageIds));

	$project->SaveDiscussionMessages($projectDiscussionMessageIds);

	if($continueFetchingLastCommitTimestamp){
		try{
			$project->FetchLastCommitTimestamp($apiKey);
		}
		catch(Exceptions\AppException $ex){
			// If we got rate limited, stop requesting more items in this loop.
			if(stripos($ex->getMessage(), 'http 429') !== false){
				$continueFetchingLastCommitTimestamp = false;
			}
			// 404, continue.
		}
	}

	if($project->IsStatusAutomaticallyUpdated){
		// Check if this project is in review.
		if($project->Status == Enums\ProjectStatusType::InProgress){
			try{
				$project->FetchReviewStatus();
			}
			catch(Exceptions\AppException){
				// 404, continue.
			}
		}

		if(
			(
				$project->Status == Enums\ProjectStatusType::InProgress
				||
				$project->Status == Enums\ProjectStatusType::AwaitingReview
				||
				$project->Status == Enums\ProjectStatusType::Reviewed
			)
			&&
			$project->LastActivityTimestamp < $oldestStalledTimestamp
		){
			// An active `Project` has stalled.
			$project->Status = Enums\ProjectStatusType::Stalled;

			// Send an email to the producer.
			$project->SendReminder(Enums\ProjectReminderType::Stalled);
		}
		elseif(
			$project->Status == Enums\ProjectStatusType::Stalled
			&&
			$project->LastActivityTimestamp >= $oldestStalledTimestamp
		){
			// Revive previously-stalled `Project`s.
			$project->Status = Enums\ProjectStatusType::InProgress;
		}
		elseif(
			$project->Status == Enums\ProjectStatusType::Stalled
			&&
			$project->LastActivityTimestamp < $oldestStalledTimestamp
			&&
			$project->GetReminder(Enums\ProjectReminderType::Stalled)?->Created < $oldestAbandonedTimestamp
		){
			// A stalled `Project` is now abandoned.
			$project->Status = Enums\ProjectStatusType::Abandoned;

			// Set the corresponding `EbookPlaceholder` to not be "in progress" any more.
			if($project->Ebook->EbookPlaceholder !== null){
				try{
					$project->Ebook->EbookPlaceholder->IsInProgress = false;
					$project->Ebook->EbookPlaceholder->Save();
				}
				catch(Exceptions\EbookPlaceholderInvalidException){
					// Pass.
				}
			}

			// Send a notification to the producer.
			$project->SendReminder(Enums\ProjectReminderType::Abandoned);
		}
	}

	$project->Save();

	sleep(random_int(10, 20));
}
