#!/bin/bash
set -e
set -o pipefail

# shellcheck source=scripts/lib/common.sh
source "$(dirname -- "$( readlink -f -- "$0"; )")/lib/common.sh"

usage(){
PrintHelp \
 "[command]$(basename "${BASH_SOURCE[0]}")[/] [[flag]-b[/],[flag]--bare[/]] [[flag]-n[/],[flag]--new-only[/] | [flag]-u[/],[flag]--update-only[/]] [[flag]-s[/],[flag]--start-letter[/] [parameter]<LETTER>[/]] [[flag]--token[/] [parameter]<TOKEN>[/]] [[flag]-v[/],[flag]--verbosity[/] [parameter]1[/] | [flag]-vv[/],[flag]--verbosity[/] [parameter]2[/]] [path][parameter]<REPOS_ROOT_DIRECTORY>[/]" \
 "$(cat << EOF
Syncs books from the [url]standardebooks.org[/] GitHub organization to [path][parameter]<REPOS_ROOT_DIRECTORY>[/].
EOF
)"\
 "$(cat << EOF
[path][parameter]<REPOS_ROOT_DIRECTORY>[/]

	The local directory where ebook repositories should be synced.
EOF
)"\
 "$(cat << EOF
[flag]-b[/],[flag]--bare[/]

	Clone bare repositories instead of working directories; useful when called on a server.


[flag]-n[/],[flag]--new-only[/]

	Only download new repositories, don't update existing ones.


[flag]-s[/],[flag]--start-letter[/] [parameter]<LETTER>[/]

	Skip repositories starting with letters prior to the specified letter.


[flag]--token[/] [parameter]<TOKEN>[/]

	Specify a GitHub access token to use for request; useful when hitting GitHub's rate limit.


[flag]-u[/],[flag]--update-only[/]

	Only update existing repositories, don't download new ones.


[flag]-v[/],[flag]--verbosity[/] [parameter]1[/]

	Display general progress updates.


[flag]-vv[/],[flag]--verbosity[/] [parameter]2[/]

	Display general progress updates and verbose Git output.
EOF
)"
}

check_arg(){
	case "$2" in
		''|"$1") ExitWithError "$3" ;;
	esac
}

# strpos `X` `Y`, return position of substring `Y` in string `X`.
str_pos(){
	x="${1%%"$2"*}"
	[[ "$x" = "$1" ]] && echo -1 || echo "${#x}"
}

# Terminate on `ctrl + c`.
trap ctrl_c INT
ctrl_c() {
	exit
}

Require "git"

if [ $# -eq 0 ] || { [ $# -eq 1 ] && { [ "$1" = "--help" ] || [ "$1" = "-h" ]; }; }; then
	usage
fi

if ! grep --version 2>/dev/null | head --lines 1 | grep --quiet 'GNU grep'; then
	ExitWithError "GNU [command]grep[/] is required. On Mac, install the GNU version via Homebrew, MacPorts, etc. and make sure it's first in [parameter]\$PATH[/]."
fi

if ! sed --version 2>/dev/null | head --lines 1 | grep --quiet 'GNU sed'; then
	ExitWithError "GNU [command]sed[/] is required. On Mac, install the GNU version via Homebrew, MacPorts, etc. and make sure it's first in [parameter]\$PATH[/]."
fi

LETTERS="abcdefghijklmnopoqrstuvwxyz"
verbosity=0
newUpdate=""
githubToken=""
target=""
bare=""
startLetter=""
startPos=-1

while [ $# -gt 0 ]; do
	case "$1" in
		-b|--bare)
			bare="--mirror"
			shift 1
			;;
		-n|--new-only)
			newUpdate="new"
			shift 1
			;;
		-u|--update-only)
			newUpdate="update"
			shift 1
			;;
		-s|--start-letter)
			check_arg '*[!b-z]*' "$2" "--start-letter is not a lowercase letter greater than [parameter]a[/]."
			startLetter="$2"
			shift 2
			;;
		-v)
			verbosity=1
			shift 1
			;;
		-vv)
			verbosity=2
			shift 1
			;;
		--verbosity)
			check_arg '*[!0-9]*' "$2" "Verbosity is not a positive integer."
			verbosity="$2"
			shift 2
			;;
		--token)
			check_arg '*[!0-9a-zA-Z_]*' "$2" "Token is empty or contains illegal characters."
			githubToken="$2"
			shift 2
			;;
		--) # Explicit end of all options.
			shift 1
			break
			;;
		-?*) # Invalid option.
			ExitWithError "Invalid option: [flag]$1[/]."
			;;
		*) # No more options.
			break
			;;
	esac
done

if [ $# -ne 1 ] || [ -z "$1" ]; then
	usage
fi

target="$1"

if ! [ -d "${target}" ]; then
	ExitWithError "Not a directory: [path]${target}[/]."
fi

if ! cd "${target}"; then
	ExitWithError "Couldn’t enter [path]${target}[/]."
fi

if [ "${startLetter}" != "" ]; then
	startPos=$(str_pos "${LETTERS}" "${startLetter}")
fi

# update any existing repositories
if [ "${newUpdate}" != "new" ]; then
	if [ "${verbosity}" -gt 0 ]; then
		printf "Updating local repositories ... \n"
	fi

	for item in ./*/; do
		# if starting letter specified, make sure we're past it
		if [ "${startPos}" -gt 0 ]; then
			repName=$(basename "${item}")
			repLetter="${repName:0:1}"
			repPos=$(str_pos "${LETTERS}" "${repLetter}")
			if [ "${repPos}" -lt "${startPos}" ]; then
				continue
			fi
		fi
	
		[ -e "${item}" ] || break

		if [ "${verbosity}" -gt 0 ]; then
			printf "Updating %s ... " "${item}"
		fi

		# if it's not a repository directory, skip it
		git -C "${item}" rev-parse > /dev/null 2>&1 || continue

		# this works whether the repository is bare or a working directory
		if [ "${verbosity}" -lt 2 ]; then
			git -C "${item}" fetch --quiet
		else
			git -C "${item}" fetch --verbose
		fi

		if [ "${verbosity}" -gt 0 ]; then
			printf "Done.\n"
		fi
	done
fi

if [ "${newUpdate}" = "update" ]; then
	exit
fi

# clone the remaining repositories
if [ "${verbosity}" -gt 0 ]; then
	printf "Cloning remote repositories ... \n"
	printf "Fetching repository urls ..."
fi

# get all of the repository names from the GitHub API, one "page" at a time
url="https://api.github.com/orgs/standardebooks/repos?per_page=100"
repoUrls=""

while true; do
	# get a "page" worth of repository URL's
	if [ -n "${githubToken}" ]; then
		response=$(curl --header "Authorization: token ${githubToken}" --silent --include "${url}") ||
			ExitWithError "Curl request failed."
	else
		response=$(curl --silent --include "${url}") ||
			ExitWithError "Curl request failed."
	fi

	if printf "%s" "${response}" | grep --quiet "^X-RateLimit-Remaining: 0$"; then
		limitReset=$(printf "%s" "${response}" | grep --only-matching --perl-regexp "^X-RateLimit-Reset: \K[0-9]+$")
		printf "You have reached your daily allowance for unauthenticated GitHub API requests.\n\
			Either wait until %s or use an OAuth token.\n\
			You can create a new token at <https://github.com/settings/tokens/new> and \
			pass it to this script with the --token option.\n\
			The token does not need any permissions.\n" "$(date --date=@"${limitReset}")" 1>&2
		exit
	fi

	# parse the response to get the current page's URL's
	currentRepoUrls=$(printf "%s" "${response}" | awk 'BEGIN { FS="\""; RS="," }; { if ($2 == "clone_url") {print $4} }')
	# add them to the full list in repoUrls
	repoUrls=$(printf "%s\n%s" "${repoUrls}" "${currentRepoUrls}")
	# set the variable to get the next "page"
	url=$(printf "%s" "${response}" | grep --only-matching --perl-regexp "<\Khttps://api.github.com/[^>]*(?=>; rel=\"next\",)") || break

	if [ "${verbosity}" -gt 0 ]; then
		printf "."
	fi
done

if [ "${verbosity}" -gt 0 ]; then
	printf " Done.\n"
fi

# skip the non-ebook repositories by removing their names from the list
repoUrls=$(printf "%s" "${repoUrls}" | grep --invert-match --regexp "/tools.git\$" --regexp "/web.git\$" --regexp "/manual.git\$" --regexp "/standard-blackletter.git\$" --regexp "/sublime-text-se-plugin.git\$" | awk 'NF')

# process the list, reading one repository at a time
printf "%s\n" "${repoUrls}" | while IFS= read -r repoUrl; do
	# make sure it's not an empty string
	[ -n "${repoUrl}" ] || continue

	# strip everything prior to the last segment of the name
	repoName="${repoUrl##*/}"
	if [ "${bare}" = "" ]; then
		repoName="${repoName%.git}"
	fi

	# if the repo already exists, skip it (handled in the update above)
	[ -d "${repoName}" ] && continue

	# if the repository name has been truncated due to GitHub's name length limits,
	# but a local clone with the full name exists, don't attempt to clone it again
	repoNameLength=$(printf "%s" "${repoName%.git}" | wc --chars)
	if [ "${repoNameLength}" -ge 100 ]; then
		if dirs=( "${repoName%.git}"*/ ) && [[ -d ${dirs[0]} ]]; then
			continue
		fi
	fi

	if [ "${verbosity}" -gt 0 ]; then
		printf "Cloning %s ... \n" "${repoUrl}"
	fi

	# clone the repository, creating either a bare or working directory based on the option
	if [ "${verbosity}" -lt 2 ]; then
		git clone --quiet ${bare} "${repoUrl}"
	else
		git clone --verbose ${bare} "${repoUrl}"
	fi

	# if a directory with the repository name doesn't exist, the clone did not complete successfully
	if ! [ -d "${repoName}" ]; then
		printf "Failed to clone %s.\n" "${repoName}." 1>&2
	elif [ "${verbosity}" -gt 0 ]; then
		printf "Done.\n"
	fi

	# if the repository doesn't have a metadata file, skip to the next repository
	git -C "${repoName}" show HEAD:src/epub/content.opf > /dev/null 2>&1 || continue

	# get the last segment of the dc:identifier from the metadata
	properName="$(git -C "${repoName}" show HEAD:src/epub/content.opf |
		grep --only-matching --extended-regexp "<dc:identifier id=\"uid\">https://standardebooks.org/ebooks/[^<]+</dc:identifier>" |
		sed --regexp-extended "s/<[^>]+?>//g" |
		sed --regexp-extended "s|https://standardebooks.org/ebooks/||g" |
		sed --regexp-extended "s|/|_|g").git"
	if [ "${bare}" = "" ]; then
		properName="${properName%.git}"
	fi

	# if the repository name isn't the same as the identifier (GitHub has a size limitation on
	# the length of a repo name; works with a lot of translators can exceed it), rename the 
	# directory to be the identifier name
	if [ "${repoName}" != "${properName}" ]; then
		if [ -d "${properName}" ]; then
			if [ "${verbosity}" -gt 0 ]; then
				printf "Not moving %s to %s: directory exists\n" "${repoName}" "${properName}"
			fi
		else
			if [ "${verbosity}" -gt 0 ]; then
				printf "Moving %s to %s\n" "${repoName}" "${properName}"
			fi
			mv "${repoName}" "${properName}"
		fi
	fi
done
